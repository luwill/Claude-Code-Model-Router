# Claude Code Model Router - 环境变量配置
#
# 复制此文件为 .env 并填入你的 API Keys
# cp .env.example .env

# ============================================
# Anthropic API (Claude 官方)
# ============================================
# 从 https://console.anthropic.com/ 获取
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxx

# ============================================
# DeepSeek API
# ============================================
# 从 https://platform.deepseek.com/ 获取
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxx

# ============================================
# Kimi API (Moonshot)
# ============================================
# 从 https://platform.kimi.ai/ 获取
KIMI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxx

# ============================================
# MiniMax CN / Token Plan API
# ============================================
# 从 https://platform.minimaxi.com/ 获取
MINIMAX_API_KEY=eyJhbGciOixxxxxxxxxxxxxxx

# ============================================
# MiniMax Global API
# ============================================
# 从 https://platform.minimax.io/ 获取
MINIMAX_GLOBAL_API_KEY=eyJhbGciOixxxxxxxxxxxxxxx

# ============================================
# Qwen API (阿里云百炼)
# ============================================
# 从 https://dashscope.console.aliyun.com/ 获取
QWEN_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxx

# ============================================
# GLM CN API (智谱 AI 国内版)
# ============================================
# 从 https://open.bigmodel.cn/ 获取
GLM_API_KEY=xxxxxxxxxxxxxxxxxxxxx

# ============================================
# GLM Global API (Z.ai 国际版)
# ============================================
# 从 https://z.ai/model-api 获取，使用 glm-global / glm-global-5.2 别名
GLM_GLOBAL_API_KEY=xxxxxxxxxxxxxxxxxxxxx

# ============================================
# Doubao Seed API (火山方舟 Volcengine，仅国内版)
# ============================================
# 从 https://console.volcengine.com/ark 获取（按量付费 / 方舟 API 调用）
# Anthropic 接入点 https://ark.cn-beijing.volces.com/api/compatible
# 使用 seed / seed-2.1-pro / seed-2.1-turbo 别名（模型 *-260628）
ARK_API_KEY=xxxxxxxxxxxxxxxxxxxxx

# Doubao Seed - Agent Plan 订阅专属 Key（接入点 https://ark.cn-beijing.volces.com/api/plan）
# 用 seed-plan / seed-plan-turbo 别名
ARK_PLAN_API_KEY=xxxxxxxxxxxxxxxxxxxxx

# ============================================
# MiMo Token Plan API
# ============================================
# 从订阅页获取，默认使用 SGP 集群：https://platform.xiaomimimo.com/#/console/plan-manage
MIMO_API_KEY=tp-xxxxxxxxxxxxxxxxxxxxx

# 如果订阅页显示 CN / AMS 集群，请改用对应变量和模型别名
MIMO_TOKEN_CN_API_KEY=tp-xxxxxxxxxxxxxxxxxxxxx
MIMO_TOKEN_AMS_API_KEY=tp-xxxxxxxxxxxxxxxxxxxxx

# ============================================
# MiMo Pay-as-you-go API
# ============================================
# 从 https://platform.xiaomimimo.com/#/console/api-keys 获取
MIMO_PAYG_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxx

# ============================================
# 网关配置（可选）
# ============================================
# 覆盖 models.yaml 中的默认配置

# 网关端口
# GATEWAY_PORT=8080

# 入站鉴权令牌（可选；若将网关绑定到非 127.0.0.1 的地址则必须设置）
# 设置后，调用方需在 "x-api-key" 或 "Authorization: Bearer <token>" 中携带此令牌。
# 仅当网关保持绑定在 127.0.0.1 时才可留空。
# CCMR_REQUIRED_AUTH_TOKEN=
# 客户端令牌覆盖（通常无需设置；默认复用 CCMR_REQUIRED_AUTH_TOKEN）
# CCMR_AUTH_TOKEN=

# 日志级别
# LOG_LEVEL=INFO

# 请求超时（秒）
# REQUEST_TIMEOUT=300
